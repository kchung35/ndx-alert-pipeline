# Data outputs ship with the repo so teammates/grader can run
# `streamlit run src/dashboard.py` immediately without a 60-minute EDGAR pull.
# `python3 run_daily.py` will still overwrite these in place with fresh data.
#
# Anything you want to exclude goes below.

# Python
__pycache__/
*.pyc
.venv/
.pytest_cache/
*.egg-info/

# OS / editor
.DS_Store
.idea/
.vscode/

# Secrets
.env
.env.local

# Runtime logs
logs/*.log

# Local newsletter/export artifacts
exports/
